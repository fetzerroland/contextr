---
import Base from '../layouts/Base.astro';
---

<Base title="Impressum — contextr.">
  <section style="padding-top: 8rem;">
    <div class="container container--narrow">
      <h1>Impressum</h1>

      <p style="margin-top: var(--space-lg); color: var(--color-text-secondary);">
        <em>Angaben gemäß § 5 TMG — wird nach Gewerbeanmeldung vervollständigt.</em>
      </p>

      <div style="margin-top: var(--space-lg);">
        <h3>Kontakt</h3>
        <p>XX</p>
        <p>Berlin, Deutschland</p>
        <p>E-Mail: <a href="mailto:hello@contextr.de">hello@contextr.de</a></p>
      </div>

      <div style="margin-top: var(--space-lg);">
        <h3>Haftungsausschluss</h3>
        <p>
          Die Inhalte dieser Website wurden mit größtmöglicher Sorgfalt erstellt.
          Für die Richtigkeit, Vollständigkeit und Aktualität der Inhalte kann jedoch keine Gewähr übernommen werden.
        </p>
      </div>

      <p style="margin-top: var(--space-xl);">
        <a href="/">← Zurück zur Startseite</a>
      </p>
    </div>
  </section>
</Base>
